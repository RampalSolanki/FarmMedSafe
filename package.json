{
  "name": "farm-management",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend/config",
    "frontend/public"
  ],
  "scripts": {
    "install-all": "npm install --workspaces",
    "start": "npm run start --workspace backend/config",
    "build": "npm run build --workspace frontend/public",
    "backend:install": "npm install --workspace backend/config",
    "backend:start": "npm run dev --workspace backend/config",
    "backend:seed": "npm run seed --workspace backend/config",
    "frontend:install": "npm install --workspace frontend/public",
    "frontend:start": "npm run start --workspace frontend/public",
    "frontend:build": "npm run build --workspace frontend/public"
  }
}
